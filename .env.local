# ─────────────────────────────────────────────────────────────────
#  AcadCode — local dev environment
#
#  Run:  vercel env pull .env.local
#  This pulls your Vercel Postgres credentials automatically.
#  You should NOT need to fill these in by hand.
# ─────────────────────────────────────────────────────────────────

# Injected automatically by `vercel env pull`:
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
